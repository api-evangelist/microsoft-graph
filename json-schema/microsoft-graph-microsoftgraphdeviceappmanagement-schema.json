        },
        "managedAppStatuses": {
          "type": "array",
          "items": {
            "$ref": "#/components/schemas/microsoft.graph.managedAppStatus"
          },
          "description": "The managed app statuses.",
          "x-ms-navigationProperty": true
        },
        "managedEBooks": {
          "type": "array",
