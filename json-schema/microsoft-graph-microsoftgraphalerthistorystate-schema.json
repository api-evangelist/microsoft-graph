{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/microsoft.graph.alertHistoryState",
  "title": "alertHistoryState",
  "required": [
    "@odata.type"
  ],
  "type": "object",
  "properties": {
    "appId": {
      "type": "string",
      "nullable": true
    },
    "assignedTo": {
      "type": "string",
      "nullable": true
    },
    "comments": {
      "type": "array",
      "items": {
        "type": "string",
        "nullable": true
      }
    },
    "feedback": {
      "anyOf": [
        {
          "$ref": "#/components/schemas/microsoft.graph.alertFeedback"
        },
        {
          "type": "object",
          "nullable": true
        }
      ]
    },
    "status": {
      "anyOf": [
        {
          "$ref": "#/components/schemas/microsoft.graph.alertStatus"
        },
        {
          "type": "object",
          "nullable": true
        }
      ]
    },
    "updatedDateTime": {
      "pattern": "^[0-9]{4,}-(0[1-9]|1[012])-(0[1-9]|[12][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]([.][0-9]{1,12})?(Z|[+-][0-9][0-9]:[0-9][0-9])$",
      "type": "string",
      "format": "date-time",
      "nullable": true
    },
    "user": {
      "type": "string",
      "nullable": true
    },
    "@odata.type": {
      "type": "string"
    }
  }
}