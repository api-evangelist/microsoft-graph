{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/microsoft.graph.deviceCompliancePolicy",
  "title": "microsoft.graph.deviceCompliancePolicy",
  "allOf": [
    {
