{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/microsoft.graph.eventMessage",
  "title": "microsoft.graph.eventMessage",
  "allOf": [
    {
      "$ref": "#/components/schemas/microsoft.graph.message"
    },
    {
      "title": "eventMessage",
      "required": [
