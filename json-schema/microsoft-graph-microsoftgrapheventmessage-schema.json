      ],
      "type": "object",
      "properties": {
        "endDateTime": {
          "anyOf": [
            {
              "$ref": "#/components/schemas/microsoft.graph.dateTimeTimeZone"
            },
            {
              "type": "object",
              "nullable": true
            }
          ]
        },
        "isAllDay": {
          "type": "boolean",
          "nullable": true
        },
        "isDelegated": {
