    }
  },
  "discriminator": {
    "propertyName": "@odata.type",
    "mapping": {
      "#microsoft.graph.appManagementApplicationConfiguration": "#/components/schemas/microsoft.graph.appManagementApplicationConfiguration",
      "#microsoft.graph.appManagementServicePrincipalConfiguration": "#/components/schemas/microsoft.graph.appManagementServicePrincipalConfiguration",
