{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/microsoft.graph.operation",
  "title": "microsoft.graph.operation",
  "allOf": [
    {
      "$ref": "#/components/schemas/microsoft.graph.entity"
    },
    {
      "title": "operation",
      "required": [
        "@odata.type"
      ],
      "type": "object",
      "properties": {
        "createdDateTime": {
          "pattern": "^[0-9]{4,}-(0[1-9]|1[012])-(0[1-9]|[12][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]([.][0-9]{1,12})?(Z|[+-][0-9][0-9]:[0-9][0-9])$",
          "type": "string",
          "description": "The start time of the operation.",
          "format": "date-time",
          "nullable": true
        },
        "lastActionDateTime": {
          "pattern": "^[0-9]{4,}-(0[1-9]|1[012])-(0[1-9]|[12][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]([.][0-9]{1,12})?(Z|[+-][0-9][0-9]:[0-9][0-9])$",
          "type": "string",
          "description": "The time of the last action of the operation.",
          "format": "date-time",
          "nullable": true
        },
        "status": {
          "anyOf": [
            {
              "$ref": "#/components/schemas/microsoft.graph.operationStatus"
            },
            {
              "type": "object",
              "nullable": true
            }
          ],
          "description": "The current status of the operation: notStarted, running, completed, failed"
        },
        "@odata.type": {
          "type": "string"
        }
      },
      "discriminator": {
        "propertyName": "@odata.type",
        "mapping": {
          "#microsoft.graph.onenoteOperation": "#/components/schemas/microsoft.graph.onenoteOperation"
        }
      }
    }
  ]
}