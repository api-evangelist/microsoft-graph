{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/microsoft.graph.artifactQuery",
  "title": "artifactQuery",
  "required": [
    "@odata.type"
  ],
  "type": "object",
  "properties": {
    "artifactType": {
      "anyOf": [
        {
          "$ref": "#/components/schemas/microsoft.graph.restorableArtifact"
        },
        {
          "type": "object",
          "nullable": true
        }
      ],
      "description": "The type of artifact to search. The possible values are: message, unknownFutureValue."
    },
    "queryExpression": {
      "type": "string",
      "description": "Specifies criteria to retrieve artifacts.",
      "nullable": true
    },
    "@odata.type": {
      "type": "string"
    }
  }
}