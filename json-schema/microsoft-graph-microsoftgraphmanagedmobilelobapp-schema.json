{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/microsoft.graph.managedMobileLobApp",
  "title": "microsoft.graph.managedMobileLobApp",
  "allOf": [
    {
      "$ref": "#/components/schemas/microsoft.graph.managedApp"
    },
    {
      "title": "managedMobileLobApp",
      "required": [
        "@odata.type"
      ],
      "type": "object",
      "properties": {
        "committedContentVersion": {
          "type": "string",
          "description": "The internal committed content version.",
          "nullable": true
        },
        "fileName": {
          "type": "string",
          "description": "The name of the main Lob application file.",
          "nullable": true
        },
        "size": {
          "type": "number",
          "description": "The total size, including all uploaded files. This property is read-only.",
          "format": "int64",
          "readOnly": true
        },
        "contentVersions": {
          "type": "array",
          "items": {
            "$ref": "#/components/schemas/microsoft.graph.mobileAppContent"
          },
          "description": "The list of content versions for this app. This property is read-only.",
          "x-ms-navigationProperty": true
        },
        "@odata.type": {
          "type": "string",
          "default": "#microsoft.graph.managedMobileLobApp"
        }
      },
      "description": "An abstract base class containing properties for all managed mobile line-of-business apps.",
      "discriminator": {
        "propertyName": "@odata.type",
        "mapping": {
          "#microsoft.graph.managedAndroidLobApp": "#/components/schemas/microsoft.graph.managedAndroidLobApp",
          "#microsoft.graph.managedIOSLobApp": "#/components/schemas/microsoft.graph.managedIOSLobApp"
        }
      }
    }
  ]
}