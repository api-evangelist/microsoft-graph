{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/microsoft.graph.accessPackageAssignmentRequestCallbackData",
  "title": "microsoft.graph.accessPackageAssignmentRequestCallbackData",
  "allOf": [
