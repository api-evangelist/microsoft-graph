          "description": "Search metadata, if the item is from a search result. Read-only."
        },
        "shared": {
          "anyOf": [
            {
              "$ref": "#/components/schemas/microsoft.graph.shared"
            },
            {
              "type": "object",
              "nullable": true
            }
