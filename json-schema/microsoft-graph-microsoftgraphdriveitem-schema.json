        "folder": {
          "anyOf": [
            {
              "$ref": "#/components/schemas/microsoft.graph.folder"
            },
            {
              "type": "object",
              "nullable": true
            }
          ],
          "description": "Folder metadata, if the item is a folder. Read-only."
        },
        "image": {
          "anyOf": [
            {
              "$ref": "#/components/schemas/microsoft.graph.image"
            },
            {
              "type": "object",
              "nullable": true
